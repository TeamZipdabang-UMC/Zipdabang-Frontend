<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@+id/my_frame"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:background="@drawable/my_round"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <androidx.constraintlayout.utils.widget.ImageFilterButton
            android:id="@+id/my_backbtn"
            android:layout_width="15.5dp"
            android:layout_height="15.2dp"
            android:layout_marginTop="8dp"
            android:clickable="false"
            android:src="@drawable/my_backbtn2"
            android:scaleType="centerCrop"
            android:layout_marginStart="30dp"
            android:layout_gravity="center_vertical|start"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1:1 문의"
            android:textSize="20dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/jipdabang_black"
            android:fontFamily="@font/notosanskrbold"
            android:layout_gravity="center_horizontal|center_vertical"/>
    </FrameLayout>



     <androidx.constraintlayout.widget.ConstraintLayout
         android:id="@+id/ct_1"
         android:layout_width="match_parent"
         android:layout_height="0dp"
         app:layout_constraintBottom_toTopOf="@id/ct_2"
         app:layout_constraintVertical_weight="1.2"
         app:layout_constraintTop_toBottomOf="@id/my_frame">
    <TextView
        android:id="@+id/email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="이메일"
        android:textSize="18sp"
        android:includeFontPadding="false"
        android:fontFamily="@font/notosanskrfont"
        android:textStyle="bold"
        android:textColor="#191919"
        android:gravity="center_vertical"
        app:layout_constraintVertical_weight="1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.2"
        app:layout_constraintStart_toStartOf="@id/et_email"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.00"
        />
         <View
             android:id="@+id/empty_1"
             android:layout_width="0dp"
             android:layout_height="wrap_content"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintHorizontal_weight="1"
             app:layout_constraintEnd_toStartOf="@id/et_email"/>

         <EditText
             android:id="@+id/et_email"
             android:layout_width="0dp"
             android:layout_height="48dp"
             android:padding="10dp"
             android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/empty_1"
             app:layout_constraintEnd_toStartOf="@id/empty_2"
             android:background="@drawable/sign_edge_round"
             app:layout_constraintHorizontal_weight="9"
             app:layout_constraintTop_toBottomOf="@id/email"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintVertical_bias="0.2">

         </EditText>

         <View
             android:id="@+id/empty_2"
             android:layout_width="0dp"
             android:layout_height="wrap_content"
             app:layout_constraintStart_toEndOf="@id/et_email"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintHorizontal_weight="1"/>

         <TextView
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:fontFamily="@font/notosanskrfont"
             android:text="이메일을 정확히 입력해주세요"
             android:textSize="12sp"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintHorizontal_bias="0.0"
             app:layout_constraintStart_toStartOf="@id/et_email"
             app:layout_constraintTop_toBottomOf="@id/et_email"
             app:layout_constraintVertical_bias="0.0" />


     </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ct_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/ct_1"
        app:layout_constraintBottom_toTopOf="@+id/ct_3"
        app:layout_constraintVertical_weight="2">


        <TextView
            android:id="@+id/content"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:text="문의사항"
            android:textSize="18sp"
            android:includeFontPadding="false"
            android:fontFamily="@font/notosanskrfont"
            android:textStyle="bold"
            android:textColor="#191919"
            android:gravity="center_vertical"
            app:layout_constraintVertical_weight="2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/et_content"
            app:layout_constraintStart_toStartOf="@id/et_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.00"
            />
        <View
            android:id="@+id/empty_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintEnd_toStartOf="@id/et_content"/>

        <EditText
            android:id="@+id/et_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toEndOf="@id/empty_3"
            app:layout_constraintEnd_toStartOf="@id/empty_4"
            android:textSize="14sp"
            android:background="@drawable/sign_edge_round"
            app:layout_constraintHorizontal_weight="9"
            android:fontFamily="@font/notosanskrfont"
            android:hint="문의할 내용을 작성해주세요"
            android:textAlignment="textStart"
            android:padding="10dp"
            android:gravity="start"
            app:layout_constraintTop_toBottomOf="@id/content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_weight="6"
            app:layout_constraintVertical_bias="0.5"
            android:layout_margin="10dp">

        </EditText>

        <View
            android:id="@+id/empty_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/et_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"/>





    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ct_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/ct_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_weight="2">


        <TextView
            android:id="@+id/tv_3_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/notosanskrfont"
            android:includeFontPadding="false"
            android:text="개인 정보 수집 및 이용"
            android:textColor="#191919"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.096"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.073" />

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:fontFamily="@font/notosanskrfont"
            android:text="문의처리를 위해 이메일, 회원정보, 기기정보, 문의내용에 포함된 개인정보를 수집하며 개인정보처리방침에 따라 3년 후 파기됩니다. "
            android:textColor="#767676"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_3_title"
            app:layout_constraintVertical_bias="0.123" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/agree"
            app:layout_constraintTop_toBottomOf="@id/tv_content"
            android:background="@drawable/sign_edge_round"
            android:padding="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[필수] : 개인 정보 수집 및 이용 동의"
                android:fontFamily="@font/notosanskrfont"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:textSize="14sp">
            </TextView>

            <ImageButton
                android:id="@+id/agree_bt"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/my_check"
                android:background="@drawable/sign_roundbtn_checking"
               android:layout_gravity="center_vertical"
                android:layout_marginStart="10dp">
            </ImageButton>
        </androidx.appcompat.widget.LinearLayoutCompat>


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/bt_question"
            android:layout_width="149dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/agree"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@drawable/quest_bg_bt_gray"
            android:text="문의하기"
            android:textAlignment="center"
            app:layout_constraintVertical_bias="0.5"
            android:fontFamily="@font/notosanskrfont"
            android:textColor="#999999"
            android:textSize="18sp"
            android:textStyle="bold"/>


</androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>





